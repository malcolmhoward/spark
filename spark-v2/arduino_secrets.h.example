/*
 * SPARK v2 Secrets Configuration
 *
 * Copy this file to arduino_secrets.h and fill in your values.
 * arduino_secrets.h is gitignored -- never commit actual credentials.
 */

/* WiFi credentials (kept for compatibility, not used in ESP-NOW mode) */
#define SECRET_SSID "YOUR_SSID"
#define SECRET_PASS "YOUR_PASSWORD"

/*
 * SECURITY WARNING: Change the PMK to your own unique value!
 * Using the default key makes your ESP-Now communication vulnerable.
 * Generate a random 16-byte key for production use.
 *
 * This MUST match the key in the AURA firmware!
 *
 * Example command to generate a random key:
 * openssl rand -hex 16
 */
#define SECRET_PMK { \
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, \
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00  \
}
